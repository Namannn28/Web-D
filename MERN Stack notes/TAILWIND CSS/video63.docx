      <span class="p-4 bg-white/5 rounded-xl border border-white/10 shadow-sm w-40 text-center">SHOPIFY</span>
    </div>

    <div class="flex justify-around items-center w-1/2 gap-x-8 text-white font-mono font-bold text-lg">
      <span class="p-4 bg-white/5 rounded-xl border border-white/10 shadow-sm w-40 text-center">STRIPE</span>
      <span class="p-4 bg-white/5 rounded-xl border border-white/10 shadow-sm w-40 text-center">PAYPAL</span>
